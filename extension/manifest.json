{
  "manifest_version": 3,
  "name": "BCI Focus & Fatigue",
  "description": "Live focus and fatigue indicator fed by a localhost LSL bridge.",
  "version": "0.1.0",
  "action": {
    "default_title": "BCI Focus & Fatigue",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "ws://localhost:8765/*"
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}

{
  "manifest_version": 3,
  "name": "Monitor Your Flow State",
  "short_name": "Tabbi",
  "description": "\"Tabbi\" the cat wanders between your tabs when you drift out of focus. See how locked in you are with our heatmap tracker!",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "alarms",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "ws://*/*",
    "wss://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "cat.js",
        "gate.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "cat-sprite-sheet.png",
        "cat sprite sheet.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_title": "Monitor your flow state. \"Tabbi\" the cat wanders between your tabs when you drift out of focus. See how locked in you are with our heatmap tracker!",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
